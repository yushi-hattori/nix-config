#!/usr/bin/env bash

echo "Attempting to stop any running instance of walker..."
pkill walker

sleep 1

if pgrep walker >/dev/null 2>&1; then
  echo "Failed to stop walker." >&2
else
  echo "Walker stopped successfully."
  echo "Starting walker..."
  walker &>/dev/null &
  disown
  echo "Walker restarted successfully."
fi
