{
  "force_keyboard_focus": true,
  "selection_wrap": true,
  "hide_action_hints": true,
  "placeholders": {
    "default": {
      "input": " Search...",
      "list": "No Results"
    }
  },
  "keybinds": {
    "quick_activate": []
  },
  "columns": {
    "symbols": 1
  },
  "providers": {
    "max_results": 256,
    "default": [
      "desktopapplications",
      "runner",
      "websearch",
      "menus"
    ],
    "prefixes": [
      {
        "prefix": "/",
        "provider": "providerlist"
      },
      {
        "prefix": ".",
        "provider": "files"
      },
      {
        "prefix": ":",
        "provider": "symbols"
      },
      {
        "prefix": "=",
        "provider": "calc"
      },
      {
        "prefix": "@",
        "provider": "websearch"
      },
      {
        "prefix": "$",
        "provider": "clipboard"
      }
    ]
  },
  "menus": [
    {
      "name": "power",
      "items": [
        {
          "label": "Shutdown",
          "exec": "shutdown now"
        },
        {
          "label": "Reboot",
          "exec": "reboot"
        },
        {
          "label": "Suspend",
          "exec": "loginctl suspend"
        },
        {
          "label": "Lock",
          "exec": "swaylock"
        }
      ]
    }
  ],
  "emergencies": [
    {
      "text": "Restart Walker",
      "command": "systemctl --user restart walker"
    }
  ]
}
