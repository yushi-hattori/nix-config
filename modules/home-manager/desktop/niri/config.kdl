// Niri configuration file (KDL)
// See https://github.com/YaLTeR/niri/wiki/Configuration:-Overview for help.
// Default config: https://github.com/niri-wm/niri/blob/main/resources/default-config.kdl

input {
    keyboard {
        xkb {
            layout "us"
            options "caps:ctrl_modifier"
        }
        repeat-delay 150
        repeat-rate 40
    }

    touchpad {
        tap
        dwt
    }

    mouse {
        // acceleration-profile "flat"
    }

    warp-mouse-to-focus
    // focus-follows-mouse
}

output "eDP-1" {
    mode "2880x1920@120.000"
    scale 1.75
    position x=4359 y=2997
}

output "DP-8" {
    mode "2560x1440@59.951"
    scale 1.0
    transform "90"
    position x=2632 y=1060
}

output "DP-10" {
    mode "2560x1440@59.951"
    scale 1.0
    position x=4072 y=1557
}

layout {
    gaps 8
    center-focused-column "always"

    preset-column-widths {
        proportion 0.25
        proportion 0.5
        proportion 0.75
        proportion 1.0
    }

    default-column-width { proportion 0.75; }

    focus-ring {
        width 2
        active-color "#b4befe"
        inactive-color "#45475a"
    }

    border {
        off
    }

    struts {
        left 0
        right 0
        top 0
        bottom 0
    }
}

spawn-at-startup "waybar"
spawn-at-startup "swaync"
spawn-at-startup "hypridle"
spawn-at-startup "xwayland-satellite"
spawn-at-startup "wl-paste" "--watch" "cliphist" "store"
spawn-at-startup "swaybg" "-i" "/home/yhattori/nix-config/modules/home-manager/misc/wallpaper/space.png" "-m" "fill"
spawn-at-startup "systemctl" "--user" "import-environment" "DISPLAY" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP"
spawn-at-startup "dbus-update-activation-environment" "--systemd" "DISPLAY" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP=niri"
spawn-at-startup "systemctl" "--user" "start" "graphical-session.target"


// Some environmental variables for screen sharing
environment {
    DISPLAY ":0"
}

animations {
    // slowdown 2.0
}

window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

// Keybindings
binds {
    // Mod is the Super key
    Mod+Shift+Slash { show-hotkey-overlay; }

    // Apps
    Mod+Return { spawn "ghostty"; }
    Mod+Space { spawn "walker"; }
    Ctrl+Space { spawn "walker"; }
    Mod+E { spawn "nautilus"; }

    // Screenshots
    Mod+Shift+S { spawn "grim" "-g" "$(slurp)" "- | swappy -f -"; }
    Print { spawn "grim" "- | swappy -f -"; }

    // Window management
    Mod+Q { close-window; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+C { center-column; }

    // Focus
    Mod+H { focus-column-left; }
    Mod+J { focus-window-or-workspace-down; }
    Mod+K { focus-window-or-workspace-up; }
    Mod+L { focus-column-right; }
    Mod+Tab { focus-column-right; }
    Mod+Right { focus-column-right; }

    // Movement
    Ctrl+Shift+H { move-column-left; }
    Ctrl+Shift+J { move-window-down; }
    Ctrl+Shift+K { move-window-up; }
    Ctrl+Shift+L { move-column-right; }

    // Column width
    Mod+R { switch-preset-column-width; }
    Mod+Shift+R { reset-window-height; }

    // Workspaces (Niri calls them workspaces)
    Mod+1 { focus-monitor "eDP-1"; }
    Mod+2 { focus-monitor "DP-10"; }
    Mod+3 { focus-monitor "DP-8"; }
    
    Mod+Shift+1 { move-column-to-monitor "eDP-1"; }
    Mod+Shift+2 { move-column-to-monitor "DP-10"; }
    Mod+Shift+3 { move-column-to-monitor "DP-8"; }
    
    // Move Workspace to Monitor
    Mod+Shift+H         { move-column-to-monitor-left; }
    Mod+Shift+J         { move-column-to-monitor-down; }
    Mod+Shift+K         { move-column-to-monitor-up; }
    Mod+Shift+L         { move-column-to-monitor-right; }

    // Focus Monitor
    Alt+Ctrl+H    { focus-monitor-left; }
    Alt+Ctrl+J    { focus-monitor-down; }
    Alt+Ctrl+K    { focus-monitor-up; }
    Alt+Ctrl+L    { focus-monitor-right; }



    // Move windows to specific outputs
    Mod+Ctrl+1 { move-column-to-monitor "eDP-1"; }
    Mod+Ctrl+2 { move-column-to-monitor "DP-8"; }
    Mod+Ctrl+3 { move-column-to-monitor "DP-10"; }

    // System
    Mod+Shift+E { quit; }
    Mod+Escape { spawn "walker" "--modules" "menus:power"; }
    Mod+Shift+V { spawn "bash" "-c" "cliphist list | walker --dmenu | cliphist decode | wl-copy"; }

    // Media keys
    XF86AudioRaiseVolume { spawn "pamixer" "--increase" "10"; }
    XF86AudioLowerVolume { spawn "pamixer" "--decrease" "10"; }
    XF86AudioMute { spawn "pamixer" "--toggle-mute"; }
    XF86AudioMicMute { spawn "pamixer" "--default-source" "--toggle-mute"; }

    XF86AudioPlay { spawn "playerctl" "play-pause"; }
    XF86AudioNext { spawn "playerctl" "next"; }
    XF86AudioPrev { spawn "playerctl" "previous"; }

    XF86MonBrightnessUp { spawn "brightnessctl" "set" "+10%"; }
    XF86MonBrightnessDown { spawn "brightnessctl" "set" "10%-"; }
}

